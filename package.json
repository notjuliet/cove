{
  "name": "cove",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "bun install --frozen-lockfile && bun run build",
    "dev": "vite --host 127.0.0.1 & bun --watch src/server/index.ts",
    "build": "vite build && bun build src/server/index.ts --target=bun --outdir=dist/server",
    "start": "bun dist/server/index.js",
    "test": "bun test",
    "lint": "oxlint --deny-warnings src tests vite.config.ts",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run test"
  },
  "dependencies": {
    "solid-js": "^1.9.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@types/bun": "^1.3.14",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tailwindcss": "^1.3.5",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-solid": "^2.11.12"
  }
}
